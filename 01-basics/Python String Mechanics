name = "ada nelson"
# 'name' is a variable (a label pointing to a value). 
# PEP 8 style guide: variable names should always be lowercase, using snake_case for multiple words.
# Text enclosed in single or double quotes creates a String data type.

#the title = method (an action that python performs on a piece of data)
# the dot indicates to act it on variable 
print (name.title())
print (name.upper())
print (name.lower())
# .title() is a method (a function belonging to a specific object type).
# The dot (.) operator accesses the method, and the parentheses () execute it.
# .lower() ensures uniform casing, which is critical for standardizing data storage and comparisons.

#using variable in a string = f string (f-format: replace variable by value)
first_name = "ada"
last_name = "Nelson"
full_name = f"{first_name} {last_name}"
print (full_name.title())
message = f"hello {full_name}"
print (message)

#WHITE SPACE 
