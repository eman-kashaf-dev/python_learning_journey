print ("languages: \n\tpython \t\njava \t\nhtml")
# \n suggests a newline
#the order of \n \t is important 

#STRIPPING WHITESPACE 
fav_lang = ' python '
fav_lang.rstrip()
#rstrip() does not change the original string — it returns a new string with right-side spaces removed
# , so you must store it in a variable or print it to see the result.
fav_lang.lstrip() #for left side
fav_lang.strip() #for both


